# =============================================================================
# PHI-PRO .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
.next/
out/
dist/
build/
*.tsbuildinfo

# Testing
coverage/
*.lcov

# Environment variables
.env
.env.*
!.env.example
!.env.*.example

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# IDE & Editors
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Turbo
.turbo/

# Debug logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel/

# PWA generated
sw.js
workbox-*.js
sw.js.map

# Claude Code (local agent settings)
.claude/

# Misc
*.tgz
.cache/
package-lock.json
"temp_response.txt"
