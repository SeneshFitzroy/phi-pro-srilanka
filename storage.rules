rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function hasRole(role) {
      return request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('MOH_ADMIN') || hasRole('SPHI');
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    function isValidDocument() {
      return request.resource.contentType.matches('application/pdf')
             && request.resource.size < 25 * 1024 * 1024; // 25MB max
    }

    // User profile photos
    match /users/{userId}/profile/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId) && isValidImage();
    }

    // Inspection evidence photos
    match /inspections/{inspectionId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isValidImage() || isValidDocument());
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Complaint attachments
    match /complaints/{complaintId}/{fileName} {
      allow read: if isAuthenticated();
      allow create: if isValidImage() || isValidDocument();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Generated reports (PDF)
    match /reports/{reportId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidDocument();
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
