rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Firestore Security Rules — PHI-PRO
    // Role hierarchy: Public (L1) < PHI (L2) < SPHI (L3) < MOH_ADMIN (L4)
    // =========================================================================

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }

    function isSupervisor() {
      return hasAnyRole(['SPHI', 'MOH_ADMIN']);
    }

    function isAdmin() {
      return hasRole('MOH_ADMIN');
    }

    function isFieldOfficer() {
      return hasAnyRole(['PHI', 'SPHI', 'MOH_ADMIN']);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ── User Profiles ─────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isUser(userId) || isSupervisor();
      allow create: if isUser(userId) || isAdmin();
      allow update: if isUser(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Food Safety (H800/H801/H802/H803) ────────────────────────────────────

    match /food_inspections/{docId} {
      allow read: if isOwner() || isSupervisor();
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['establishmentName', 'type', 'createdBy', 'createdAt'])
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── School Health (H1214/H1046/H1015/H1247/H1014) ────────────────────────

    match /school_health/{docId} {
      allow read: if isOwner() || isSupervisor();
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['schoolName', 'type', 'createdBy', 'createdAt'])
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Epidemiology (H399/H411/Health-160/SIV) ──────────────────────────────

    match /epidemiology/{docId} {
      allow read: if isOwner() || isSupervisor();
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['type', 'createdBy', 'createdAt'])
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Occupational Health (H1203/H1204/H1205) ──────────────────────────────

    match /occupational_health/{docId} {
      allow read: if isOwner() || isSupervisor();
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['facilityName', 'type', 'createdBy', 'createdAt'])
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Administration (H795/H796/PHI-1/H1200) ───────────────────────────────

    match /administration/{docId} {
      allow read: if isOwner() || isSupervisor();
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['type', 'createdBy', 'createdAt'])
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Internal Complaints (PHI-facing) ─────────────────────────────────────

    match /complaints/{docId} {
      allow read: if resource.data.isPublic == true || isAuthenticated();
      allow create: if hasRequiredFields(['subject', 'description', 'contactEmail']);
      allow update: if isFieldOfficer();
      allow delete: if isAdmin();
    }

    // ── Public Complaints (citizen portal — no auth required) ─────────────────
    // Collection: public_complaints
    // Written by citizens via /public/complaints page.
    // Read by PHI officers and above for triage.

    match /public_complaints/{docId} {
      allow read: if isFieldOfficer();
      allow create: if true
                    && hasRequiredFields(['trackingId', 'type', 'description', 'location', 'district', 'status', 'createdAt']);
      allow update: if isFieldOfficer();
      allow delete: if isAdmin();
    }

    // ── Public Health Alerts ──────────────────────────────────────────────────
    // Readable by everyone. Written only by supervisors.

    match /public_alerts/{docId} {
      allow read: if true;
      allow create: if isSupervisor()
                    && hasRequiredFields(['title', 'severity', 'createdBy', 'createdAt']);
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ── Published Reports (public open-data) ─────────────────────────────────

    match /published_reports/{docId} {
      allow read: if true;
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['title', 'type', 'createdBy', 'createdAt']);
      allow update: if isFieldOfficer();
      allow delete: if isAdmin();
    }

    // ── Food Grades (public — H800 published results) ─────────────────────────
    // Readable by everyone. Written only by field officers.

    match /food_grades/{docId} {
      allow read: if true;
      allow create: if isFieldOfficer();
      allow update: if isFieldOfficer();
      allow delete: if isAdmin();
    }

    // ── Health Permits & Certificates ─────────────────────────────────────────
    // Public READ for certificate verification (/public/verify).
    // Write requires field officer auth.

    match /permits/{docId} {
      allow read: if true;
      allow create: if isFieldOfficer()
                    && hasRequiredFields(['type', 'holder', 'createdBy', 'createdAt']);
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ── Payment Records (citizen payment submissions) ──────────────────────────
    // Citizens create payment records via /public/payments.
    // Only field officers can read/update payment status.

    match /payment_records/{docId} {
      allow read: if isFieldOfficer();
      allow create: if true
                    && hasRequiredFields(['paymentRef', 'serviceType', 'payerName', 'phone', 'amount', 'status', 'createdAt']);
      allow update: if isFieldOfficer();
      allow delete: if isAdmin();
    }

    // ── Audit Log (immutable) ─────────────────────────────────────────────────

    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Deny all else ─────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
